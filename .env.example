# Secret utilisé pour signer les sessions (JWT). Générez une vraie valeur
# aléatoire en production, par exemple avec : openssl rand -base64 48
JWT_SECRET=change-me-in-production

# Chaîne de connexion à votre base Postgres (ex. Neon, gratuit, sans limite
# de durée). Créez un compte sur https://neon.tech, créez un projet, puis
# copiez la "Connection string" (elle ressemble à
# postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require)
DATABASE_URL=

# Clé API OpenRouteService (gratuite) pour calculer la distance réelle par la
# route au lieu d'une estimation à vol d'oiseau corrigée. Créez un compte
# gratuit sur https://openrouteservice.org/dev/#/signup puis collez la clé
# ici. Sans cette clé, l'application fonctionne quand même, avec une
# estimation moins précise.
# ORS_API_KEY=

# Identifiants France Travail (francetravail.io) pour afficher le nombre
# réel d'offres d'emploi par métier/département sur la page "Pourquoi
# JobSwap" et dans l'onglet "Marché" du tableau de bord. Créez un compte
# gratuit sur https://francetravail.io, créez une application, associez-la
# à l'API "Offres d'emploi". Sans ces identifiants, ces statistiques sont
# simplement masquées (pas d'erreur, pas de chiffre inventé).
# FT_CLIENT_ID=
# FT_CLIENT_SECRET=

# Aucune clé n'est nécessaire pour les statistiques d'établissements
# (INSEE Sirene, via l'API publique recherche-entreprises.api.gouv.fr).

# Envoi d'e-mails (réinitialisation de mot de passe). Créez un compte
# gratuit sur https://resend.com (3000 e-mails/mois gratuits), récupérez
# une clé API. Sans cette clé, la demande de réinitialisation ne renvoie
# aucune erreur visible (par sécurité) mais aucun e-mail n'est envoyé.
# RESEND_API_KEY=
# RESEND_FROM="JobSwap <onboarding@resend.dev>"

# Adresse publique de votre application (utilisée dans le lien de
# réinitialisation de mot de passe envoyé par e-mail). Sur Render, mettez
# l'URL de votre service (ex. https://jobswap-app.onrender.com). Si non
# défini, l'application déduit l'adresse automatiquement depuis la requête.
# APP_URL=

NODE_ENV=development
