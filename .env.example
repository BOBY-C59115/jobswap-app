# Secret utilisé pour signer les sessions (JWT). Générez une vraie valeur
# aléatoire en production, par exemple avec : openssl rand -base64 48
JWT_SECRET=change-me-in-production

# Chemin du fichier SQLite (laisser vide pour utiliser db/jobswap.sqlite3 par défaut)
# DATABASE_PATH=/data/jobswap.sqlite3

NODE_ENV=development
